-- Services
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

-- Player Variables
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Configuration
local START_POS = Vector3.new(-137, 60, 1297)
local END_POS = Vector3.new(-156, 32, 8276)
local SIMULATED_WALKSPEED = 200

-- Create ScreenGUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "TeleportToggleGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

-- Create Toggle Button
local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0, 200, 0, 50)
toggleButton.Position = UDim2.new(0.5, -100, 0.1, 0)
toggleButton.BackgroundColor3 = Color3.fromRGB(240, 50, 50)
toggleButton.Text = "Loop: OFF"
toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleButton.Font = Enum.Font.SourceSansBold
toggleButton.TextSize = 24
toggleButton.Parent = screenGui

-- State Variable
local isLooping = false

-- Function to calculate duration based on distance and speed
local function getTweenDuration(p1, p2, speed)
	local distance = (p1 - p2).Magnitude
	return distance / speed
end

-- Main Loop Function
local function runLoop()
	while isLooping do
		local character = player.Character or player.CharacterAdded:Wait()
		local hrp = character:WaitForChild("HumanoidRootPart", 5)
		local humanoid = character:WaitForChild("Humanoid", 5)
		
		if hrp and humanoid and humanoid.Health > 0 then
			-- 1. Teleport to initial position
			hrp.CFrame = CFrame.new(START_POS)
			task.wait(0.1)
			
			-- Enable PlatformStand so animations/physics don't interfere
			humanoid.PlatformStand = true
			
			-- 2. Setup and play Tween (Linear ensuring absolutely constant speed)
			local duration = getTweenDuration(START_POS, END_POS, SIMULATED_WALKSPEED)
			local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
			local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(END_POS)})
			
			tween:Play()
			
			-- Track status
			local tweenCompleted = false
			local connection
			connection = tween.Completed:Connect(function()
				tweenCompleted = true
			end)
			
			-- Monitor the tween actively
			while not tweenCompleted and isLooping and humanoid.Health > 0 do
				task.wait(0.1)
			end
			
			-- Cleanup connection immediately
			if connection then connection:Disconnect() end
			
			-- 3. Drop to the floor / Handle interruption or death
			if not isLooping or humanoid.Health <= 0 then
				tween:Cancel()
				if humanoid.Health > 0 then
					humanoid.PlatformStand = false
				end
				break
			end
			
			-- Stop the tween explicitly at the destination and drop character
			tween:Cancel() 
			humanoid.PlatformStand = false
			
			-- 4. Wait for the player to die/respawn
			-- If your game setup kills the player at the end automatically, we wait here:
			if humanoid.Health > 0 then
				-- Optional: force reset if the game environment doesn't do it automatically
				-- humanoid.Health = 0 
			end
			
			-- Wait until the character is dead/removed before counting the respawn time
			while player.Character == character and humanoid.Health > 0 and isLooping do
				task.wait(0.1)
			end
			
			-- 5. Wait 5 seconds for respawn cooldown, then 0.5 seconds before repeating
			task.wait(5)
			task.wait(0.5)
		else
			task.wait(1)
		end
	end
end

-- Toggle Button Logic
toggleButton.MouseButton1Click:Connect(function()
	isLooping = not isLooping
	
	if isLooping then
		toggleButton.Text = "Loop: ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
		task.spawn(runLoop)
	else
		toggleButton.Text = "Loop: OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(240, 50, 50)
	end
end)
