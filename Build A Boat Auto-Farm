-- Services
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

-- Player Variables
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Configuration
local START_POS = Vector3.new(-137, 60, 1297)
local END_POS = Vector3.new(-156, 32, 8276)
local SIMULATED_WALKSPEED = 200
local STUCK_THRESHOLD = 5 

-- Create ScreenGUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AutoFarmToggleGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

-- Create Toggle Button
local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0, 200, 0, 50)
toggleButton.Position = UDim2.new(0.5, -100, 0.1, 0)
toggleButton.BackgroundColor3 = Color3.fromRGB(240, 50, 50)
toggleButton.Text = "Auto-Farm: OFF"
toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleButton.Font = Enum.Font.SourceSansBold
toggleButton.TextSize = 24
toggleButton.Parent = screenGui

-- State Variable
local isLooping = false

-- Function to calculate duration based on distance and speed
local function getTweenDuration(p1, p2, speed)
	local distance = (p1 - p2).Magnitude
	return distance / speed
end

-- Main Loop Function
local function runLoop()
	while isLooping do
		local character = player.Character
		local humanoid = character and character:FindFirstChild("Humanoid")
		
		-- Check if player is currently dead or character is missing
		if not character or not character:IsDescendantOf(workspace) or not humanoid or humanoid.Health <= 0 then
			-- Wait exactly 5 seconds after health hits 0
			task.wait(5)
			
			-- Wait for a completely new character to spawn and finish loading
			if isLooping then
				character = player.CharacterAdded:Wait()
				humanoid = character:WaitForChild("Humanoid", 10)
				
				-- Ensure they are fully healed up before moving forward
				while humanoid and humanoid.Health < humanoid.MaxHealth do
					task.wait(0.1)
				end
			end
		end
		
		-- Safety check in case toggle was turned off during the waits
		if not isLooping then break end
		
		local hrp = character:WaitForChild("HumanoidRootPart", 5)
		
		if hrp and humanoid and humanoid.Health > 0 then
			-- 1. Teleport to initial position
			hrp.CFrame = CFrame.new(START_POS)
			task.wait(0.2) 
			
			-- Enable PlatformStand so physics/falling states don't stop the tween
			humanoid.PlatformStand = true
			
			-- 2. Setup and play Tween
			local duration = getTweenDuration(START_POS, END_POS, SIMULATED_WALKSPEED)
			local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
			local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(END_POS)})
			
			tween:Play()
			
			-- Watchdog variables to monitor if the character gets stuck
			local lastPosition = hrp.Position
			local timeStuck = 0
			local tweenCompleted = false
			
			local connection
			connection = tween.Completed:Connect(function()
				tweenCompleted = true
			end)
			
			-- 3. Active Monitoring Loop (Checks every 0.1s for completion, death, or stuck status)
			while not tweenCompleted and isLooping and humanoid.Health > 0 and character:IsDescendantOf(workspace) do
				task.wait(0.1)
				
				-- Stuck detection logic
				if (hrp.Position - lastPosition).Magnitude < 1 then
					timeStuck = timeStuck + 0.1
					if timeStuck >= STUCK_THRESHOLD then
						warn("[Auto-Farm] Character detected as stuck! Forcing reset...")
						humanoid.Health = 0 -- Kill the character to drop health to 0
						break
					end
				else
					lastPosition = hrp.Position
					timeStuck = 0 
				end
			end
			
			if connection then connection:Disconnect() end
			tween:Cancel()
			
			-- Clean up platform stand if we stopped mid-way safely
			if not isLooping and humanoid.Health > 0 then
				humanoid.PlatformStand = false
				break
			end
			
			-- 4. Drop to floor / Post-Tween Wait
			if humanoid.Health > 0 then
				humanoid.PlatformStand = false
				
				-- Wait until the character naturally dies/despawns or is removed
				while character:IsDescendantOf(workspace) and humanoid.Health > 0 and isLooping do
					task.wait(0.1)
				end
			end
			
			-- Short break to prevent engine strain before restarting the loop verification
			task.wait(0.1)
		else
			task.wait(0.5)
		end
	end
end

-- Toggle Button Logic
toggleButton.MouseButton1Click:Connect(function()
	isLooping = not isLooping
	
	if isLooping then
		toggleButton.Text = "Auto-Farm: ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
		task.spawn(runLoop)
	else
		toggleButton.Text = "Auto-Farm: OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(240, 50, 50)
	end
end)
